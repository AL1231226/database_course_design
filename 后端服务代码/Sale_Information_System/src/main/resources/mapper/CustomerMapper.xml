<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.Sale_Information_System.Mapper.CustomerMapper">


    <resultMap id="BaseResultMap" type="Customer">
        <id column="customer_id" property="customerId"/>
        <result column="customer_name" property="customerName"/>
        <result column="contact_name" property="contactName"/>
        <result column="address" property="address"/>
        <result column="zip_code" property="zipCode"/>
        <result column="phone" property="phone"/>
    </resultMap>
    <select id="getAllCustomers" resultMap="BaseResultMap">
        SELECT * FROM customer
    </select>
    <select id="getCustomerById" resultMap="BaseResultMap">
        SELECT * FROM customer WHERE customer_id = #{customerId}
    </select>
    <insert id="insert">
        INSERT INTO customer (customer_id, customer_name, contact_name, address, zip_code, phone)
        VALUES (#{customerId}, #{customerName}, #{contactName}, #{address}, #{zipCode}, #{phone})
    </insert>
    <update id="update">
        UPDATE customer
        SET customer_name = #{customerName}, contact_name = #{contactName}, address = #{address},
        zip_code = #{zipCode}, phone = #{phone}
        WHERE customer_id = #{customerId}
    </update>
    <delete id="delete">
        DELETE FROM customer WHERE customer_id = #{customerId}
    </delete>

    </mapper>